<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F2F5">

    <!-- Header bar -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="#1565C0"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:text="Custom RecyclingView"
        android:textColor="#FFFFFF"
        android:textSize="17sp"
        android:textStyle="bold" />

    <!-- Scroll-state indicator -->
    <TextView
        android:id="@+id/tv_scroll_state"
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:background="#0D47A1"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:text="Scroll: Idle"
        android:textColor="#B3E5FC"
        android:textSize="11sp" />

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:padding="8dp">

        <Button
            android:id="@+id/btn_add_item"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="+ Add Item"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_btn_green" />

        <Button
            android:id="@+id/btn_clear_all"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="Clear All"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_btn_red" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#DDDDDD" />

    <!-- The custom list -->
    <com.ikechi.studio.recyclingview.view.RecyclingView
        android:id="@+id/recycling_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
